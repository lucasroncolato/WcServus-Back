  occurredAt  DateTime          @default(now())
  createdAt   DateTime          @default(now())
  church      Church            @relation(fields: [churchId], references: [id], onDelete: Cascade)
  ministry    Ministry?         @relation(fields: [ministryId], references: [id], onDelete: SetNull)
  servant     Servant?          @relation(fields: [servantId], references: [id], onDelete: SetNull)
  actorUser   User?             @relation("TimelineEntryActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([churchId, occurredAt])
  @@index([scope, occurredAt])
  @@index([ministryId, occurredAt])
  @@index([servantId, occurredAt])
}

model ChurchSettings {
  id                          String   @id @default(cuid())
  churchId                    String   @unique
  timezone                    String   @default("America/Sao_Paulo")
  locale                      String   @default("pt-BR")
  operationalWeekStartsOn     Int      @default(1)
  defaultJourneyEnabled       Boolean  @default(true)
  requireScheduleConfirmation Boolean  @default(true)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
  church                      Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@index([churchId])
}

model ChurchBranding {
  id             String   @id @default(cuid())
  churchId       String   @unique
  logoUrl        String?
  primaryColor   String?  @default("#1D4ED8")
  secondaryColor String?  @default("#0F172A")
  accentColor    String?  @default("#16A34A")
  welcomeMessage String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  church         Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@index([churchId])
}

model ChurchModule {
  id        String          @id @default(cuid())
  churchId  String
  moduleKey ChurchModuleKey
  enabled   Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  church    Church          @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@unique([churchId, moduleKey])
  @@index([churchId, enabled])
}

model ChurchAutomationPreference {
  id                          String   @id @default(cuid())
  churchId                    String   @unique
  enabled                     Boolean  @default(true)
  overdueGraceDays            Int      @default(0)
  stalledTrackDays            Int      @default(30)
  noServiceAlertDays          Int      @default(45)
  incompleteScheduleWindowHrs Int      @default(48)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
  church                      Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@index([churchId])
}

model Plan {
  id            String         @id @default(cuid())
  code          String         @unique
  name          String
  description   String?
  active        Boolean        @default(true)
  interval      PlanInterval   @default(MONTHLY)
  priceCents    Int            @default(0)
  maxServants   Int?
  maxUsers      Int?
  maxMinistries Int?
  modules       Json?
  createdBy     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  createdByUser User?          @relation("PlanCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  subscriptions Subscription[]
  churchPlans   ChurchPlan[]

  @@index([active])
}

model Subscription {
  id            String             @id @default(cuid())
  churchId      String
  planId        String
  status        SubscriptionStatus @default(TRIAL)
  trialEndsAt   DateTime?
  startsAt      DateTime?
  endsAt        DateTime?
  createdBy     String?
  metadata      Json?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  church        Church             @relation(fields: [churchId], references: [id], onDelete: Cascade)
  plan          Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)
  createdByUser User?              @relation("SubscriptionCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([churchId, status])
  @@index([planId, status])
}

model ChurchPlan {
  id             String             @id @default(cuid())
  churchId       String
  planId         String
  status         SubscriptionStatus @default(TRIAL)
  startsAt       DateTime?
  endsAt         DateTime?
  limitsSnapshot Json?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  church         Church             @relation(fields: [churchId], references: [id], onDelete: Cascade)
  plan           Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@unique([churchId])
  @@index([planId, status])
}

model UserMinistryBinding {
  id         String    @id @default(cuid())
  userId     String
  ministryId String?
  teamId     String?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ministry   Ministry? @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  team       Team?     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, ministryId, teamId])
  @@index([userId])
  @@index([ministryId])
  @@index([teamId])
}

model UserPermissionOverride {
  id            String           @id @default(cuid())
  userId        String
  permissionKey String
  effect        PermissionEffect
  reason        String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionKey])
  @@index([userId])
  @@index([permissionKey])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  churchId  String
  type      String
  title     String
  message   String
  link      String?
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  church    Church    @relation(fields: [churchId], references: [id], onDelete: Restrict)

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@index([type])
  @@index([churchId])
}

model NotificationTemplate {
  id         String                     @id @default(cuid())
  eventKey   String
  channel    NotificationChannel
  provider   NotificationProvider?      @default(MOCK)
  name       String
  content    String
  variables  Json?
  status     NotificationTemplateStatus @default(ACTIVE)
  createdAt  DateTime                   @default(now())
  updatedAt  DateTime                   @updatedAt
  queueItems NotificationQueue[]
  logs       NotificationLog[]

  @@unique([eventKey, channel])
  @@index([channel, status])
}

model NotificationPreference {
  id        String              @id @default(cuid())
  userId    String?
  servantId String?
  channel   NotificationChannel
  enabled   Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  user      User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  servant   Servant?            @relation(fields: [servantId], references: [id], onDelete: Cascade)

  @@unique([userId, channel])
  @@unique([servantId, channel])
  @@index([channel, enabled])
}

model NotificationQueue {
  id                String                  @id @default(cuid())
  eventKey          String
  channel           NotificationChannel     @default(WHATSAPP)
  provider          NotificationProvider    @default(MOCK)
  status            NotificationQueueStatus @default(PENDING)
  userId            String?
  servantId         String?
  recipientPhone    String
  recipientName     String?
  templateId        String?
  payload           Json?
  renderedMessage   String
  attemptCount      Int                     @default(0)
  maxAttempts       Int                     @default(3)
  nextRetryAt       DateTime                @default(now())
  lockedAt          DateTime?
  processedAt       DateTime?
  providerMessageId String?
  lastError         String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  user              User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  servant           Servant?                @relation(fields: [servantId], references: [id], onDelete: SetNull)
  template          NotificationTemplate?   @relation(fields: [templateId], references: [id], onDelete: SetNull)
  logs              NotificationLog[]

  @@index([channel, status, nextRetryAt])
  @@index([userId, createdAt])
  @@index([servantId, createdAt])
}

model NotificationLog {
  id                String                     @id @default(cuid())
  queueId           String?
  eventKey          String
  channel           NotificationChannel        @default(WHATSAPP)
  provider          NotificationProvider       @default(MOCK)
  status            NotificationDeliveryStatus
  userId            String?
  servantId         String?
  recipientPhone    String
  templateId        String?
  payload           Json?
  providerMessageId String?
  error             String?
  attempt           Int                        @default(1)
  sentAt            DateTime?
  createdAt         DateTime                   @default(now())
  queue             NotificationQueue?         @relation(fields: [queueId], references: [id], onDelete: SetNull)
  template          NotificationTemplate?      @relation(fields: [templateId], references: [id], onDelete: SetNull)
  user              User?                      @relation(fields: [userId], references: [id], onDelete: SetNull)
  servant           Servant?                   @relation(fields: [servantId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([status, channel])
  @@index([eventKey, createdAt])
}

model NotificationSystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}
