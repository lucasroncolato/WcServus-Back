generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  PASTOR
  COORDENADOR
  SERVO
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum UserScope {
  GLOBAL
  MINISTRY
  EQUIPE
  SELF
}

enum TeamStatus {
  ACTIVE
  INACTIVE
}

enum PermissionEffect {
  ALLOW
  DENY
}

enum Gender {
  MASCULINO
  FEMININO
  OUTRO
}

enum ServantStatus {
  RECRUTAMENTO
  RECICLAGEM
  ATIVO
  INATIVO
  AFASTADO
}

enum TrainingStatus {
  PENDING
  COMPLETED
}

enum ServantApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Aptitude {
  SOCIAL
  OPERACIONAL
  TECNICO
  APOIO
  LIDERANCA
}

enum WorshipServiceType {
  DOMINGO
  QUINTA
  ESPECIAL
  CEIA
  VIGILIA
  CONGRESSO
}

enum WorshipServiceStatus {
  PLANEJADO
  CONFIRMADO
  FINALIZADO
  CANCELADO
}

enum ScheduleStatus {
  ASSIGNED
  CONFIRMED
  SWAPPED
  CANCELLED
}

enum ScheduleResponseStatus {
  PENDING
  CONFIRMED
  DECLINED
}

enum ScheduleSlotStatus {
  OPEN
  ASSIGNED
  PENDING_CONFIRMATION
  CONFIRMED
  DECLINED
  NO_SHOW
  COMPLETED
  SWAPPED
}

enum ScheduleVersionStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ScheduleSlotChangeType {
  ASSIGNMENT
  REPLACEMENT
  ABSENCE_REPLACEMENT
  FILL_OPEN_SLOT
  AUTO_GENERATED
  STATUS_UPDATE
}

enum Shift {
  MORNING
  AFTERNOON
  EVENING
}

enum AttendanceStatus {
  PRESENTE
  FALTA
  FALTA_JUSTIFICADA
}

enum PastoralVisitStatus {
  ABERTA
  EM_ANDAMENTO
  RESOLVIDA
}

enum DevotionalStatus {
  DONE
  NOT_DONE
}

enum MonthlyFastingStatus {
  PENDING
  COMPLETED
  SKIPPED
}

enum TalentStage {
  RECRUTA
  EM_TREINAMENTO
  EM_AVALIACAO
  APROVADO
  REPROVADO
}

enum TalentReviewStatus {
  NOT_REQUIRED
  PENDING_ADMIN_REVIEW
  ADMIN_CONFIRMED_REJECTION
  ADMIN_REVERSED_REJECTION
}

enum AlertStatus {
  OPEN
  RESOLVED
}

enum AuditAction {
  CREATE
  UPDATE
  STATUS_CHANGE
  VISIT_RESOLVED
  SCHEDULE_SWAP
  CREATE_SERVANT
  UPDATE_SERVANT
  CREATE_MINISTRY
  UPDATE_MINISTRY
  GENERATE_SCHEDULE
  ASSIGN
  SWAP
  FILL
  RESOLVE_PASTORAL_PENDING
  TRAINING_CHANGE
  USER_SCOPE_CHANGE
  USER_ROLE_CHANGE
  USER_LOGIN
  USER_LOGOUT
  SCHEDULE_PUBLISH
  SLOT_ASSIGNED
  SLOT_CONFIRMED
  SLOT_DECLINED
  SLOT_NO_SHOW
  SLOT_COMPLETED
  SLOT_SWAPPED
  ATTENDANCE_REGISTERED
  PASTORAL_ACTION
  MINISTRY_TASK_TEMPLATE_CREATED
  MINISTRY_TASK_TEMPLATE_UPDATED
  MINISTRY_TASK_OCCURRENCE_CREATED
  MINISTRY_TASK_ASSIGNED
  MINISTRY_TASK_PROGRESS_UPDATED
  MINISTRY_TASK_COMPLETED
  MINISTRY_TASK_CANCELLED
  MINISTRY_TASK_REASSIGNED
  MINISTRY_TASK_REALLOCATION_REQUESTED
  MINISTRY_TASK_REALLOCATED_AUTOMATICALLY
  MINISTRY_TASK_REALLOCATED_MANUALLY
  MINISTRY_TASK_UNASSIGNED_AFTER_SCALE_CHANGE
  MINISTRY_TASK_ASSIGNEE_ADDED
  MINISTRY_TASK_ASSIGNEE_REMOVED
  MINISTRY_TASK_OVERDUE
  MINISTRY_TASK_RECURRING_GENERATED
  MINISTRY_TASK_DUE_SOON
  GAMIFICATION_POINTS_GRANTED
  GAMIFICATION_LEVEL_UPDATED
  GAMIFICATION_ACHIEVEMENT_UNLOCKED
  DELETE
}

enum NotificationChannel {
  IN_APP
  WHATSAPP
}

enum NotificationTemplateStatus {
  ACTIVE
  INACTIVE
}

enum NotificationDeliveryStatus {
  SUCCESS
  FAILED
}

enum NotificationQueueStatus {
  PENDING
  PROCESSING
  RETRYING
  SENT
  FAILED
}

enum NotificationProvider {
  MOCK
  META_CLOUD
}

enum SupportRequestType {
  GERAL
  DADOS
  AUTORIZACAO
  OUTRO
}

enum SupportRequestStatus {
  ABERTO
  EM_ANALISE
  RESOLVIDO
}

enum MinistryTaskRecurrenceType {
  EVERY_SERVICE
  WEEKLY
  MONTHLY
  FIRST_SERVICE_OF_MONTH
  LAST_SERVICE_OF_MONTH
  CUSTOM
  MANUAL
}

enum MinistryTaskAssigneeMode {
  OPTIONAL
  REQUIRED
}

enum MinistryTaskOccurrenceStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  OVERDUE
  CANCELLED
}

enum MinistryTaskChecklistItemStatus {
  PENDING
  DONE
  NOT_APPLICABLE
}

enum MinistryTaskReallocationMode {
  MANUAL
  AUTO_EQUAL_DISTRIBUTION
  AUTO_BEST_MATCH
  UNASSIGN
}

enum MinistryTaskReallocationStatus {
  NONE
  PENDING_REALLOCATION
  REASSIGNED
  UNASSIGNED
  CANCELLED
}

enum MinistryTaskAssignmentChangeType {
  ASSIGN
  REASSIGN_MANUAL
  REASSIGN_AUTO
  UNASSIGN
}

enum MinistryTaskAssigneeRole {
  PRIMARY
  SUPPORT
  REVIEWER
}

enum MinistryTaskOccurrencePriority {
  LOW
  MEDIUM
  HIGH
}

enum MinistryTaskOccurrenceCriticality {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum JourneyLogType {
  SERVICE
  TASK
  CHECKLIST
  TRAINING
  TRACK
  EVENT
  SUBSTITUTE
  HELP
  MILESTONE
}

enum AutomationTriggerType {
  TIME
  EVENT
  CONDITION
}

enum AutomationActionType {
  TASK_MARK_OVERDUE
  TASK_NOTIFY_DUE_SOON
  TASK_NOTIFY_COORDINATOR_OVERDUE
  TASK_ALERT_UNASSIGNED
  SCHEDULE_ALERT_INCOMPLETE
  SCHEDULE_ALERT_UNCONFIRMED
  SCHEDULE_FOLLOWUP_DECLINED
  TRAINING_ALERT_PENDING
  TRACK_ALERT_STALLED
  TRACK_MARK_STAGNATED
  JOURNEY_REGISTER_EVENT
}

enum ChurchModuleKey {
  ANALYTICS
  AUTOMATIONS
  TIMELINE
  REPORTS
  NOTIFICATIONS
  TASKS
  SCHEDULES
  JOURNEY
}

enum PlanInterval {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
}

enum TimelineScope {
  CHURCH
  MINISTRY
  SERVANT
}

enum TimelineEntryType {
  SERVICE_COMPLETED
  TASK_COMPLETED
  TRAINING_COMPLETED
  TRACK_PROGRESS
  SCHEDULE_PUBLISHED
  TASK_OVERDUE
  AUTOMATION_TRIGGERED
  CHURCH_MILESTONE
  MINISTRY_EVENT
  PASTORAL_ALERT
  GENERIC_EVENT
}

model Church {
  id                      String                      @id @default(cuid())
  name                    String
  city                    String?
  state                   String?
  active                  Boolean                     @default(true)
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt
  users                   User[]
  ministries              Ministry[]
  teams                   Team[]
  servants                Servant[]
  worshipServices         WorshipService[]
  schedules               Schedule[]
  scheduleSlots           ScheduleSlot[]
  attendances             Attendance[]
  pastoralVisits          PastoralVisit[]
  pastoralAlerts          PastoralAlert[]
  pastoralWeeklyFollowUps PastoralWeeklyFollowUp[]
  notifications           Notification[]
  scheduleVersions        ScheduleVersion[]
  ministryTaskTemplates   MinistryTaskTemplate[]
  ministryTaskOccurrences MinistryTaskOccurrence[]
  servantJourneys         ServantJourney[]
  journeyMilestones       JourneyMilestone[]
  servantMilestones       ServantMilestone[]
  journeyLogs             JourneyLog[]
  growthTracks            GrowthTrack[]
  timelineEntries         TimelineEntry[]
  servantGrowthProgress   ServantGrowthProgress[]
  servantMonthlyStats     ServantMonthlyStats[]
  auditLogs               AuditLog[]
  automationRules         AutomationRule[]
  settings                ChurchSettings?
  branding                ChurchBranding?
  modules                 ChurchModule[]
  automationPreferences   ChurchAutomationPreference?
  plans                   ChurchPlan[]
  subscriptions           Subscription[]
  automationExecutionLogs AutomationExecutionLog[]

  @@index([active])
  @@index([name])
}

model User {
  id                                String                                    @id @default(cuid())
  name                              String
  email                             String                                    @unique
  passwordHash                      String
  role                              Role
  scope                             UserScope                                 @default(GLOBAL)
  status                            UserStatus                                @default(ACTIVE)
  mustChangePassword                Boolean                                   @default(false)
  servantId                         String?                                   @unique
  phone                             String?
  avatarUrl                         String?
  lastLoginAt                       DateTime?
  churchId                          String
  deletedAt                         DateTime?
  deletedBy                         String?
  createdAt                         DateTime                                  @default(now())
  updatedAt                         DateTime                                  @updatedAt
  church                            Church                                    @relation(fields: [churchId], references: [id], onDelete: Restrict)
  servant                           Servant?                                  @relation(fields: [servantId], references: [id], onDelete: SetNull)
  refreshTokens                     RefreshToken[]
  passwordResetTokens               PasswordResetToken[]
  coordinatedMinistries             Ministry[]
  ledTeams                          Team[]                                    @relation("TeamLeader")
  assignedSchedules                 Schedule[]                                @relation("AssignedSchedules")
  assignedScheduleSlots             ScheduleSlot[]                            @relation("AssignedScheduleSlots")
  performedScheduleSlotChanges      ScheduleSlotChange[]                      @relation("PerformedScheduleSlotChanges")
  scheduleResponses                 ScheduleResponseHistory[]                 @relation("RespondedScheduleAssignments")
  scheduleSwapHistory               ScheduleSwapHistory[]                     @relation("SwappedByUser")
  registeredAttendances             Attendance[]                              @relation("RegisteredAttendances")
  createdPastoralVisits             PastoralVisit[]                           @relation("CreatedPastoralVisits")
  resolvedPastoralVisits            PastoralVisit[]                           @relation("ResolvedPastoralVisits")
  createdAlerts                     PastoralAlert[]                           @relation("AlertCreatedBy")
  resolvedAlerts                    PastoralAlert[]                           @relation("AlertResolvedBy")
  requestedServantApprovals         Servant[]                                 @relation("ServantApprovalRequestedBy")
  approvedServantApprovals          Servant[]                                 @relation("ServantApprovalApprovedBy")
  reviewedServantMinistryTrainings  ServantMinistry[]                         @relation("ServantMinistryTrainingReviewedBy")
  pastoralWeeklyFollowUps           PastoralWeeklyFollowUp[]                  @relation("PastoralWeeklyFollowUpResponsible")
  registeredDevotionals             DailyDevotional[]                         @relation("DailyDevotionalRegisteredBy")
  registeredFastings                MonthlyFasting[]                          @relation("MonthlyFastingRegisteredBy")
  rejectedTalents                   Talent[]                                  @relation("TalentRejectedBy")
  reviewedTalents                   Talent[]                                  @relation("TalentReviewedBy")
  supportRequests                   SupportRequest[]                          @relation("SupportRequestAuthor")
  handledSupportRequests            SupportRequest[]                          @relation("SupportRequestHandler")
  auditLogs                         AuditLog[]
  scopeBindings                     UserMinistryBinding[]
  permissionOverrides               UserPermissionOverride[]
  notifications                     Notification[]
  notificationPreferences           NotificationPreference[]
  notificationLogs                  NotificationLog[]
  notificationQueue                 NotificationQueue[]
  createdScheduleVersions           ScheduleVersion[]
  createdMinistryTaskTemplates      MinistryTaskTemplate[]                    @relation("MinistryTaskTemplateCreatedBy")
  assignedMinistryTaskOccurrences   MinistryTaskOccurrence[]                  @relation("MinistryTaskOccurrenceCompletedBy")
  checkedMinistryTaskChecklistItems MinistryTaskOccurrenceChecklistItem[]     @relation("MinistryTaskChecklistCheckedBy")
  reassignedMinistryTaskOccurrences MinistryTaskOccurrence[]                  @relation("MinistryTaskOccurrenceLastReassignedBy")
  ministryTaskAssignmentHistory     MinistryTaskOccurrenceAssignmentHistory[] @relation("MinistryTaskOccurrenceAssignmentChangedBy")
  ministryTaskOccurrenceAssignees   MinistryTaskOccurrenceAssignee[]          @relation("MinistryTaskOccurrenceAssigneeLinkedUser")
  createdGrowthTracks               GrowthTrack[]                             @relation("GrowthTrackCreatedBy")
  createdGrowthTrackSteps           GrowthTrackStep[]                         @relation("GrowthTrackStepCreatedBy")
  verifiedGrowthProgress            ServantGrowthProgress[]                   @relation("GrowthProgressVerifiedBy")
  createdAutomationRules            AutomationRule[]                          @relation("AutomationRuleCreatedBy")
  timelineEntries                   TimelineEntry[]                           @relation("TimelineEntryActor")
  createdPlans                      Plan[]                                    @relation("PlanCreatedBy")
  subscriptions                     Subscription[]                            @relation("SubscriptionCreatedBy")

  @@index([role])
  @@index([scope])
  @@index([status])
  @@index([servantId])
  @@index([churchId])
  @@index([deletedAt])
  @@index([createdAt])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Ministry {
  id                      String                   @id @default(cuid())
  churchId                String
  name                    String                   @unique
  description             String?
  color                   String?
  icon                    String?
  popText                 String?
  coordinatorUserId       String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  deletedAt               DateTime?
  deletedBy               String?
  church                  Church                   @relation(fields: [churchId], references: [id], onDelete: Restrict)
  coordinator             User?                    @relation(fields: [coordinatorUserId], references: [id])
  servants                Servant[]
  servantMinistries       ServantMinistry[]
  userScopeBindings       UserMinistryBinding[]
  schedules               Schedule[]
  scheduleSlots           ScheduleSlot[]
  teams                   Team[]
  pastoralWeeklyFollowUps PastoralWeeklyFollowUp[]
  responsibilities        MinistryResponsibility[]
  scheduleVersionSlots    ScheduleVersionSlot[]
  ministryTaskTemplates   MinistryTaskTemplate[]
  ministryTaskOccurrences MinistryTaskOccurrence[]
  growthTracks            GrowthTrack[]
  servantMonthlyStats     ServantMonthlyStats[]
  TimelineEntry           TimelineEntry[]

  @@index([coordinatorUserId])
  @@index([churchId])
  @@index([deletedAt])
}

model Team {
  id                String                @id @default(cuid())
  name              String
  slug              String?
  description       String?
  ministryId        String
  churchId          String
  leaderUserId      String?
  status            TeamStatus            @default(ACTIVE)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  deletedAt         DateTime?
  deletedBy         String?
  church            Church                @relation(fields: [churchId], references: [id], onDelete: Restrict)
  ministry          Ministry              @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  leader            User?                 @relation("TeamLeader", fields: [leaderUserId], references: [id], onDelete: SetNull)
  servants          Servant[]
  userScopeBindings UserMinistryBinding[]

  @@unique([ministryId, name])
  @@index([ministryId])
  @@index([leaderUserId])
  @@index([status])
  @@index([churchId])
  @@index([deletedAt])
}

model Servant {
  id                                String                                    @id @default(cuid())
  name                              String
  phone                             String?
  gender                            Gender?
  birthDate                         DateTime?
  status                            ServantStatus                             @default(RECRUTAMENTO)
  trainingStatus                    TrainingStatus                            @default(PENDING)
  approvalStatus                    ServantApprovalStatus                     @default(APPROVED)
  approvalRequestedByUserId         String?
  approvedByUserId                  String?
  approvalUpdatedAt                 DateTime?
  approvalNotes                     String?
  aptitude                          Aptitude?
  mainMinistryId                    String?
  teamId                            String?
  churchId                          String
  notes                             String?
  joinedAt                          DateTime?
  consecutiveAbsences               Int                                       @default(0)
  monthlyAbsences                   Int                                       @default(0)
  createdAt                         DateTime                                  @default(now())
  updatedAt                         DateTime                                  @updatedAt
  deletedAt                         DateTime?
  deletedBy                         String?
  church                            Church                                    @relation(fields: [churchId], references: [id], onDelete: Restrict)
  mainMinistry                      Ministry?                                 @relation(fields: [mainMinistryId], references: [id])
  team                              Team?                                     @relation(fields: [teamId], references: [id], onDelete: SetNull)
  servantMinistries                 ServantMinistry[]
  schedules                         Schedule[]
  scheduleSlots                     ScheduleSlot[]
  availabilities                    ServantAvailability[]
  attendances                       Attendance[]
  pastoralVisits                    PastoralVisit[]
  pastoralAlerts                    PastoralAlert[]
  pastoralWeeklyFollowUps           PastoralWeeklyFollowUp[]
  devotionals                       DailyDevotional[]
  monthlyFastings                   MonthlyFasting[]
  responsibilities                  MinistryResponsibility[]                  @relation("ResponsibilityOwnerServant")
  talents                           Talent[]
  statusHistory                     ServantStatusHistory[]
  userAccount                       User?
  approvalRequestedBy               User?                                     @relation("ServantApprovalRequestedBy", fields: [approvalRequestedByUserId], references: [id], onDelete: SetNull)
  approvedBy                        User?                                     @relation("ServantApprovalApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  notificationPreferences           NotificationPreference[]
  notificationLogs                  NotificationLog[]
  notificationQueue                 NotificationQueue[]
  scheduleVersionSlots              ScheduleVersionSlot[]
  assignedMinistryTaskOccurrences   MinistryTaskOccurrence[]                  @relation("MinistryTaskAssignedServant")
  originMinistryTaskOccurrences     MinistryTaskOccurrence[]                  @relation("MinistryTaskOriginAssignedServant")
  ministryTaskAssignmentHistoryFrom MinistryTaskOccurrenceAssignmentHistory[] @relation("MinistryTaskAssignmentHistoryFromServant")
  ministryTaskAssignmentHistoryTo   MinistryTaskOccurrenceAssignmentHistory[] @relation("MinistryTaskAssignmentHistoryToServant")
  ministryTaskAssignees             MinistryTaskOccurrenceAssignee[]
  journey                           ServantJourney?
  journeyMilestones                 ServantMilestone[]
  journeyLogs                       JourneyLog[]
  timelineEntries                   TimelineEntry[]
  growthProgress                    ServantGrowthProgress[]
  monthlyStats                      ServantMonthlyStats[]

  @@index([name])
  @@index([status])
  @@index([trainingStatus])
  @@index([approvalStatus])
  @@index([approvalRequestedByUserId])
  @@index([approvedByUserId])
  @@index([mainMinistryId])
  @@index([teamId])
  @@index([churchId])
  @@index([deletedAt])
}

model ServantMinistry {
  id                       String         @id @default(cuid())
  servantId                String
  ministryId               String
  trainingStatus           TrainingStatus @default(PENDING)
  trainingCompletedAt      DateTime?
  trainingReviewedByUserId String?
  trainingNotes            String?
  createdAt                DateTime       @default(now())
  servant                  Servant        @relation(fields: [servantId], references: [id], onDelete: Cascade)
  ministry                 Ministry       @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  trainingReviewedBy       User?          @relation("ServantMinistryTrainingReviewedBy", fields: [trainingReviewedByUserId], references: [id], onDelete: SetNull)

  @@unique([servantId, ministryId])
  @@index([ministryId])
  @@index([ministryId, trainingStatus])
  @@index([trainingReviewedByUserId])
}

model ServantStatusHistory {
  id         String         @id @default(cuid())
  servantId  String
  fromStatus ServantStatus?
  toStatus   ServantStatus
  reason     String?
  createdAt  DateTime       @default(now())
  servant    Servant        @relation(fields: [servantId], references: [id], onDelete: Cascade)

  @@index([servantId, createdAt])
}

model WorshipService {
  id                      String                   @id @default(cuid())
  churchId                String
  type                    WorshipServiceType
  title                   String
  serviceDate             DateTime
  startTime               String
  notes                   String?
  status                  WorshipServiceStatus     @default(PLANEJADO)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  deletedAt               DateTime?
  deletedBy               String?
  church                  Church                   @relation(fields: [churchId], references: [id], onDelete: Restrict)
  schedules               Schedule[]
  scheduleSlots           ScheduleSlot[]
  scheduleVersions        ScheduleVersion[]
  attendances             Attendance[]
  ministryTaskOccurrences MinistryTaskOccurrence[]

  @@unique([serviceDate, startTime, title])
  @@index([serviceDate])
  @@index([type])
  @@index([churchId])
  @@index([deletedAt])
}

model ScheduleVersion {
  id               String                @id @default(cuid())
  worshipServiceId String
  churchId         String
  versionNumber    Int
  status           ScheduleVersionStatus @default(DRAFT)
  createdBy        String
  createdAt        DateTime              @default(now())
  worshipService   WorshipService        @relation(fields: [worshipServiceId], references: [id], onDelete: Cascade)
  church           Church                @relation(fields: [churchId], references: [id], onDelete: Restrict)
  createdByUser    User                  @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  slots            ScheduleVersionSlot[]

  @@unique([worshipServiceId, versionNumber])
  @@index([worshipServiceId, status])
  @@index([churchId])
}

model ScheduleVersionSlot {
  id                String                  @id @default(cuid())
  scheduleVersionId String
  ministryId        String
  responsibilityId  String?
  assignedServantId String?
  status            ScheduleSlotStatus      @default(OPEN)
  position          Int                     @default(1)
  createdAt         DateTime                @default(now())
  scheduleVersion   ScheduleVersion         @relation(fields: [scheduleVersionId], references: [id], onDelete: Cascade)
  ministry          Ministry                @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  responsibility    MinistryResponsibility? @relation(fields: [responsibilityId], references: [id], onDelete: SetNull)
  assignedServant   Servant?                @relation(fields: [assignedServantId], references: [id], onDelete: SetNull)

  @@index([scheduleVersionId, position])
  @@index([ministryId])
  @@index([responsibilityId])
  @@index([assignedServantId])
}

model Schedule {
  id                      String                    @id @default(cuid())
  serviceId               String
  servantId               String
  ministryId              String
  churchId                String
  assignedByUserId        String
  status                  ScheduleStatus            @default(ASSIGNED)
  responseStatus          ScheduleResponseStatus    @default(PENDING)
  responseAt              DateTime?
  declineReason           String?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  deletedAt               DateTime?
  deletedBy               String?
  church                  Church                    @relation(fields: [churchId], references: [id], onDelete: Restrict)
  service                 WorshipService            @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  servant                 Servant                   @relation(fields: [servantId], references: [id], onDelete: Cascade)
  ministry                Ministry                  @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  assignedBy              User                      @relation("AssignedSchedules", fields: [assignedByUserId], references: [id])
  swapHistoryFrom         ScheduleSwapHistory[]     @relation("SwapFromSchedule")
  swapHistoryTo           ScheduleSwapHistory[]     @relation("SwapToSchedule")
  responseHistory         ScheduleResponseHistory[]
  pastoralWeeklyFollowUps PastoralWeeklyFollowUp[]
  scheduleSlots           ScheduleSlot[]

  @@unique([serviceId, servantId, ministryId])
  @@index([serviceId])
  @@index([servantId])
  @@index([ministryId])
  @@index([status])
  @@index([responseStatus])
  @@index([churchId])
  @@index([deletedAt])
}

model ScheduleSlot {
  id                String                  @id @default(cuid())
  serviceId         String
  ministryId        String
  churchId          String
  scheduleId        String?
  responsibilityId  String?
  functionName      String
  slotLabel         String?
  position          Int                     @default(1)
  required          Boolean                 @default(true)
  requiredTraining  Boolean                 @default(true)
  blocked           Boolean                 @default(false)
  blockedReason     String?
  status            ScheduleSlotStatus      @default(OPEN)
  assignedServantId String?
  assignedByUserId  String?
  notes             String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  deletedAt         DateTime?
  deletedBy         String?
  church            Church                  @relation(fields: [churchId], references: [id], onDelete: Restrict)
  service           WorshipService          @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  ministry          Ministry                @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  schedule          Schedule?               @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  responsibility    MinistryResponsibility? @relation(fields: [responsibilityId], references: [id], onDelete: SetNull)
  assignedServant   Servant?                @relation(fields: [assignedServantId], references: [id], onDelete: SetNull)
