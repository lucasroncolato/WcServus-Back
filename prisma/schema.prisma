model ServantGrowthProgress {
  id            String          @id @default(cuid())
  churchId      String?
  servantId     String
  growthTrackId String
  stepId        String
  completed     Boolean         @default(false)
  completedAt   DateTime?
  progressValue Float           @default(0)
  notes         String?
  verifiedBy    String?
  updatedAt     DateTime        @updatedAt
  church        Church?         @relation(fields: [churchId], references: [id], onDelete: SetNull)
  servant       Servant         @relation(fields: [servantId], references: [id], onDelete: Cascade)
  growthTrack   GrowthTrack     @relation(fields: [growthTrackId], references: [id], onDelete: Cascade)
  step          GrowthTrackStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  verifiedByUser User?          @relation("GrowthProgressVerifiedBy", fields: [verifiedBy], references: [id], onDelete: SetNull)

  @@unique([servantId, stepId])
  @@index([churchId, servantId])
  @@index([growthTrackId, completed])
}

/// @deprecated Legacy gamification artifact.
model ServantRankingSnapshot {
  id               String    @id @default(cuid())
  churchId         String?
  ministryId       String?
  servantId        String
  referenceMonth   DateTime
  totalPoints      Int
  positionChurch   Int?
  positionMinistry Int?
  createdAt        DateTime  @default(now())
  church           Church?   @relation(fields: [churchId], references: [id], onDelete: SetNull)
  ministry         Ministry? @relation(fields: [ministryId], references: [id], onDelete: SetNull)
  servant          Servant   @relation(fields: [servantId], references: [id], onDelete: Cascade)

  @@unique([servantId, referenceMonth, ministryId])
  @@index([churchId, referenceMonth, positionChurch])
  @@index([ministryId, referenceMonth, positionMinistry])
}

model ServantMonthlyStats {
  id                  String    @id @default(cuid())
  churchId            String?
  ministryId          String?
  servantId           String
  referenceMonth      DateTime
  attendanceConfirmed Int       @default(0)
  absences            Int       @default(0)
  tasksCompleted      Int       @default(0)
  tasksOverdue        Int       @default(0)
  checklistPerfect    Int       @default(0)
  pointsEarned        Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  church              Church?   @relation(fields: [churchId], references: [id], onDelete: SetNull)
  ministry            Ministry? @relation(fields: [ministryId], references: [id], onDelete: SetNull)
  servant             Servant   @relation(fields: [servantId], references: [id], onDelete: Cascade)

  @@unique([servantId, referenceMonth, ministryId])
  @@index([churchId, referenceMonth])
  @@index([ministryId, referenceMonth])
}

model AuditLog {
  id        String      @id @default(cuid())
  action    AuditAction
  entity    String
  entityId  String
  before    Json?
  after     Json?
  metadata  Json?
  userId    String?
  createdAt DateTime    @default(now())
  user      User?       @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([action])
  @@index([createdAt])
}

model UserMinistryBinding {
  id         String    @id @default(cuid())
  userId     String
  ministryId String?
  teamId     String?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ministry   Ministry? @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  team       Team?     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, ministryId, teamId])
  @@index([userId])
  @@index([ministryId])
  @@index([teamId])
}

model UserPermissionOverride {
  id            String           @id @default(cuid())
  userId        String
  permissionKey String
  effect        PermissionEffect
  reason        String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionKey])
  @@index([userId])
  @@index([permissionKey])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  churchId  String?
  type      String
  title     String
  message   String
  link      String?
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  church    Church?   @relation(fields: [churchId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@index([type])
  @@index([churchId])
}

model NotificationTemplate {
  id         String                     @id @default(cuid())
  eventKey   String
  channel    NotificationChannel
  provider   NotificationProvider?      @default(MOCK)
  name       String
  content    String
  variables  Json?
  status     NotificationTemplateStatus @default(ACTIVE)
  createdAt  DateTime                   @default(now())
  updatedAt  DateTime                   @updatedAt
  queueItems NotificationQueue[]
  logs       NotificationLog[]

  @@unique([eventKey, channel])
  @@index([channel, status])
}

model NotificationPreference {
  id        String              @id @default(cuid())
  userId    String?
  servantId String?
  channel   NotificationChannel
  enabled   Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  user      User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  servant   Servant?            @relation(fields: [servantId], references: [id], onDelete: Cascade)

  @@unique([userId, channel])
  @@unique([servantId, channel])
  @@index([channel, enabled])
}

model NotificationQueue {
  id                String                  @id @default(cuid())
  eventKey          String
  channel           NotificationChannel     @default(WHATSAPP)
  provider          NotificationProvider    @default(MOCK)
  status            NotificationQueueStatus @default(PENDING)
  userId            String?
  servantId         String?
  recipientPhone    String
  recipientName     String?
  templateId        String?
  payload           Json?
  renderedMessage   String
  attemptCount      Int                     @default(0)
  maxAttempts       Int                     @default(3)
  nextRetryAt       DateTime                @default(now())
  lockedAt          DateTime?
  processedAt       DateTime?
  providerMessageId String?
  lastError         String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  user              User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  servant           Servant?                @relation(fields: [servantId], references: [id], onDelete: SetNull)
  template          NotificationTemplate?   @relation(fields: [templateId], references: [id], onDelete: SetNull)
  logs              NotificationLog[]

  @@index([channel, status, nextRetryAt])
  @@index([userId, createdAt])
  @@index([servantId, createdAt])
}

model NotificationLog {
  id                String                     @id @default(cuid())
  queueId           String?
  eventKey          String
  channel           NotificationChannel        @default(WHATSAPP)
  provider          NotificationProvider       @default(MOCK)
  status            NotificationDeliveryStatus
  userId            String?
  servantId         String?
  recipientPhone    String
  templateId        String?
  payload           Json?
  providerMessageId String?
  error             String?
  attempt           Int                        @default(1)
  sentAt            DateTime?
  createdAt         DateTime                   @default(now())
  queue             NotificationQueue?         @relation(fields: [queueId], references: [id], onDelete: SetNull)
  template          NotificationTemplate?      @relation(fields: [templateId], references: [id], onDelete: SetNull)
  user              User?                      @relation(fields: [userId], references: [id], onDelete: SetNull)
  servant           Servant?                   @relation(fields: [servantId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([status, channel])
  @@index([eventKey, createdAt])
}

model NotificationSystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}
