generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  PASTOR
  COORDENADOR
  SERVO
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum UserScope {
  GLOBAL
  SETOR
  EQUIPE
  SELF
}

enum TeamStatus {
  ACTIVE
  INACTIVE
}

enum PermissionEffect {
  ALLOW
  DENY
}

enum Gender {
  MASCULINO
  FEMININO
  OUTRO
}

enum ServantStatus {
  RECRUTAMENTO
  RECICLAGEM
  ATIVO
  INATIVO
  AFASTADO
}

enum TrainingStatus {
  PENDING
  COMPLETED
}

enum ServantApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Aptitude {
  SOCIAL
  OPERACIONAL
  TECNICO
  APOIO
  LIDERANCA
}

enum WorshipServiceType {
  DOMINGO
  QUINTA
  ESPECIAL
  CEIA
  VIGILIA
  CONGRESSO
}

enum WorshipServiceStatus {
  PLANEJADO
  CONFIRMADO
  FINALIZADO
  CANCELADO
}

enum ScheduleStatus {
  ASSIGNED
  CONFIRMED
  SWAPPED
  CANCELLED
}

enum ScheduleResponseStatus {
  PENDING
  CONFIRMED
  DECLINED
}

enum ScheduleSlotStatus {
  OPEN
  ASSIGNED
  PENDING
  CONFIRMED
  CONFLICT
  SWAPPED
  CANCELLED
}

enum ScheduleSlotChangeType {
  ASSIGNMENT
  REPLACEMENT
  ABSENCE_REPLACEMENT
  FILL_OPEN_SLOT
  AUTO_GENERATED
  STATUS_UPDATE
}

enum Shift {
  MORNING
  AFTERNOON
  EVENING
}

enum AttendanceStatus {
  PRESENTE
  FALTA
  FALTA_JUSTIFICADA
}

enum PastoralVisitStatus {
  ABERTA
  EM_ANDAMENTO
  RESOLVIDA
}

enum DevotionalStatus {
  DONE
  NOT_DONE
}

enum MonthlyFastingStatus {
  PENDING
  COMPLETED
  SKIPPED
}

enum TalentStage {
  RECRUTA
  EM_TREINAMENTO
  EM_AVALIACAO
  APROVADO
  REPROVADO
}

enum TalentReviewStatus {
  NOT_REQUIRED
  PENDING_ADMIN_REVIEW
  ADMIN_CONFIRMED_REJECTION
  ADMIN_REVERSED_REJECTION
}

enum AlertStatus {
  OPEN
  RESOLVED
}

enum AuditAction {
  CREATE
  UPDATE
  STATUS_CHANGE
  VISIT_RESOLVED
  SCHEDULE_SWAP
  DELETE
}

enum NotificationChannel {
  IN_APP
  WHATSAPP
}

enum NotificationTemplateStatus {
  ACTIVE
  INACTIVE
}

enum NotificationDeliveryStatus {
  SUCCESS
  FAILED
}

enum NotificationQueueStatus {
  PENDING
  PROCESSING
  RETRYING
  SENT
  FAILED
}

enum NotificationProvider {
  MOCK
  META_CLOUD
}

enum SupportRequestType {
  GERAL
  DADOS
  AUTORIZACAO
  OUTRO
}

enum SupportRequestStatus {
  ABERTO
  EM_ANALISE
  RESOLVIDO
}

enum RewardSource {
  DEVOTIONAL_DAILY
  FASTING_MONTHLY
  ATTENDANCE_PRESENT
  SCHEDULE_CONFIRMED
  TASK_COMPLETED
  MANUAL
}

model User {
  id                     String              @id @default(cuid())
  name                   String
  email                  String              @unique
  passwordHash           String
  role                   Role
  scope                  UserScope           @default(GLOBAL)
  status                 UserStatus          @default(ACTIVE)
  mustChangePassword     Boolean             @default(false)
  servantId              String?             @unique
  phone                  String?
  avatarUrl              String?
  lastLoginAt            DateTime?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  servant                Servant?            @relation(fields: [servantId], references: [id], onDelete: SetNull)
  refreshTokens          RefreshToken[]
  passwordResetTokens    PasswordResetToken[]
  coordinatedSectors     Sector[]
  ledTeams               Team[]              @relation("TeamLeader")
  assignedSchedules      Schedule[]          @relation("AssignedSchedules")
  assignedScheduleSlots  ScheduleSlot[]      @relation("AssignedScheduleSlots")
  performedScheduleSlotChanges ScheduleSlotChange[] @relation("PerformedScheduleSlotChanges")
  scheduleResponses      ScheduleResponseHistory[] @relation("RespondedScheduleAssignments")
  scheduleSwapHistory    ScheduleSwapHistory[] @relation("SwappedByUser")
  registeredAttendances  Attendance[]        @relation("RegisteredAttendances")
  createdPastoralVisits  PastoralVisit[]     @relation("CreatedPastoralVisits")
  resolvedPastoralVisits PastoralVisit[]     @relation("ResolvedPastoralVisits")
  createdAlerts          PastoralAlert[]     @relation("AlertCreatedBy")
  resolvedAlerts         PastoralAlert[]     @relation("AlertResolvedBy")
  requestedServantApprovals Servant[]        @relation("ServantApprovalRequestedBy")
  approvedServantApprovals  Servant[]        @relation("ServantApprovalApprovedBy")
  reviewedServantSectorTrainings ServantSector[] @relation("ServantSectorTrainingReviewedBy")
  pastoralWeeklyFollowUps   PastoralWeeklyFollowUp[] @relation("PastoralWeeklyFollowUpResponsible")
  registeredDevotionals     DailyDevotional[] @relation("DailyDevotionalRegisteredBy")
  registeredFastings        MonthlyFasting[]  @relation("MonthlyFastingRegisteredBy")
  rejectedTalents           Talent[]          @relation("TalentRejectedBy")
  reviewedTalents           Talent[]          @relation("TalentReviewedBy")
  supportRequests           SupportRequest[]  @relation("SupportRequestAuthor")
  handledSupportRequests    SupportRequest[]  @relation("SupportRequestHandler")
  grantedRewards            ServantReward[]   @relation("ServantRewardGrantedBy")
  auditLogs              AuditLog[]
  scopeBindings          UserScopeBinding[]
  permissionOverrides    UserPermissionOverride[]
  notifications          Notification[]
  notificationPreferences NotificationPreference[]
  notificationLogs        NotificationLog[]
  notificationQueue       NotificationQueue[]

  @@index([role])
  @@index([scope])
  @@index([status])
  @@index([servantId])
  @@index([createdAt])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Sector {
  id                String    @id @default(cuid())
  name              String    @unique
  description       String?
  color             String?
  icon              String?
  popText           String?
  coordinatorUserId String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  coordinator       User?     @relation(fields: [coordinatorUserId], references: [id])
  servants          Servant[]
  servantSectors    ServantSector[]
  userScopeBindings UserScopeBinding[]
  schedules         Schedule[]
  scheduleSlots     ScheduleSlot[]
  teams             Team[]
  pastoralWeeklyFollowUps PastoralWeeklyFollowUp[]
  responsibilities  MinistryResponsibility[]

  @@index([coordinatorUserId])
}

model Team {
  id                String      @id @default(cuid())
  name              String
  slug              String?
  description       String?
  sectorId          String
  leaderUserId      String?
  status            TeamStatus  @default(ACTIVE)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  sector            Sector      @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  leader            User?       @relation("TeamLeader", fields: [leaderUserId], references: [id], onDelete: SetNull)
  servants          Servant[]
  userScopeBindings UserScopeBinding[]

  @@index([sectorId])
  @@index([leaderUserId])
  @@index([status])
  @@unique([sectorId, name])
}

model Servant {
  id                String               @id @default(cuid())
  name              String
  phone             String?
  gender            Gender?
  birthDate         DateTime?
  status            ServantStatus        @default(RECRUTAMENTO)
  trainingStatus    TrainingStatus       @default(PENDING)
  approvalStatus    ServantApprovalStatus @default(APPROVED)
  approvalRequestedByUserId String?
  approvedByUserId  String?
  approvalUpdatedAt DateTime?
  approvalNotes     String?
  aptitude          Aptitude?
  mainSectorId      String?
  teamId            String?
  notes             String?
  joinedAt          DateTime?
  consecutiveAbsences Int                @default(0)
  monthlyAbsences   Int                  @default(0)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  mainSector        Sector?              @relation(fields: [mainSectorId], references: [id])
  team              Team?                @relation(fields: [teamId], references: [id], onDelete: SetNull)
  servantSectors    ServantSector[]
  schedules         Schedule[]
  scheduleSlots     ScheduleSlot[]
  availabilities    ServantAvailability[]
  attendances       Attendance[]
  pastoralVisits    PastoralVisit[]
  pastoralAlerts    PastoralAlert[]
  pastoralWeeklyFollowUps PastoralWeeklyFollowUp[]
  devotionals       DailyDevotional[]
  monthlyFastings   MonthlyFasting[]
  responsibilities  MinistryResponsibility[] @relation("ResponsibilityOwnerServant")
  rewards           ServantReward[]
  talents           Talent[]
  statusHistory     ServantStatusHistory[]
  userAccount       User?
  approvalRequestedBy User?              @relation("ServantApprovalRequestedBy", fields: [approvalRequestedByUserId], references: [id], onDelete: SetNull)
  approvedBy        User?                @relation("ServantApprovalApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  notificationPreferences NotificationPreference[]
  notificationLogs        NotificationLog[]
  notificationQueue       NotificationQueue[]

  @@index([name])
  @@index([status])
  @@index([trainingStatus])
  @@index([approvalStatus])
  @@index([approvalRequestedByUserId])
  @@index([approvedByUserId])
  @@index([mainSectorId])
  @@index([teamId])
}

model ServantSector {
  id        String   @id @default(cuid())
  servantId String
  sectorId  String
  trainingStatus TrainingStatus @default(PENDING)
  trainingCompletedAt DateTime?
  trainingReviewedByUserId String?
  trainingNotes String?
  createdAt DateTime @default(now())
  servant   Servant  @relation(fields: [servantId], references: [id], onDelete: Cascade)
  sector    Sector   @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  trainingReviewedBy User? @relation("ServantSectorTrainingReviewedBy", fields: [trainingReviewedByUserId], references: [id], onDelete: SetNull)

  @@unique([servantId, sectorId])
  @@index([sectorId])
  @@index([sectorId, trainingStatus])
  @@index([trainingReviewedByUserId])
}

model ServantStatusHistory {
  id          String       @id @default(cuid())
  servantId   String
  fromStatus  ServantStatus?
  toStatus    ServantStatus
  reason      String?
  createdAt   DateTime     @default(now())
  servant     Servant      @relation(fields: [servantId], references: [id], onDelete: Cascade)

  @@index([servantId, createdAt])
}

model WorshipService {
  id          String               @id @default(cuid())
  type        WorshipServiceType
  title       String
  serviceDate DateTime
  startTime   String
  notes       String?
  status      WorshipServiceStatus @default(PLANEJADO)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  schedules   Schedule[]
  scheduleSlots ScheduleSlot[]
  attendances Attendance[]

  @@index([serviceDate])
  @@index([type])
  @@unique([serviceDate, startTime, title])
}

model Schedule {
  id               String         @id @default(cuid())
  serviceId        String
  servantId        String
  sectorId         String
  assignedByUserId String
  status           ScheduleStatus @default(ASSIGNED)
  responseStatus   ScheduleResponseStatus @default(PENDING)
  responseAt       DateTime?
  declineReason    String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  service          WorshipService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  servant          Servant        @relation(fields: [servantId], references: [id], onDelete: Cascade)
  sector           Sector         @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  assignedBy       User           @relation("AssignedSchedules", fields: [assignedByUserId], references: [id])
  swapHistoryFrom  ScheduleSwapHistory[] @relation("SwapFromSchedule")
  swapHistoryTo    ScheduleSwapHistory[] @relation("SwapToSchedule")
  responseHistory  ScheduleResponseHistory[]
  pastoralWeeklyFollowUps PastoralWeeklyFollowUp[]
  scheduleSlots ScheduleSlot[]

  @@index([serviceId])
  @@index([servantId])
  @@index([sectorId])
  @@index([status])
  @@index([responseStatus])
  @@unique([serviceId, servantId, sectorId])
}

model ScheduleSlot {
  id                String             @id @default(cuid())
  serviceId         String
  sectorId          String
  scheduleId        String?
  responsibilityId  String?
  functionName      String
  slotLabel         String?
  position          Int                @default(1)
  required          Boolean            @default(true)
  requiredTraining  Boolean            @default(true)
  blocked           Boolean            @default(false)
  blockedReason     String?
  status            ScheduleSlotStatus @default(OPEN)
  assignedServantId String?
  assignedByUserId  String?
  notes             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  service           WorshipService     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  sector            Sector             @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  schedule          Schedule?          @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  responsibility    MinistryResponsibility? @relation(fields: [responsibilityId], references: [id], onDelete: SetNull)
  assignedServant   Servant?           @relation(fields: [assignedServantId], references: [id], onDelete: SetNull)
  assignedBy        User?              @relation("AssignedScheduleSlots", fields: [assignedByUserId], references: [id], onDelete: SetNull)
  changes           ScheduleSlotChange[]

  @@index([serviceId, sectorId])
  @@index([status])
  @@index([assignedServantId])
  @@index([responsibilityId])
  @@index([scheduleId])
  @@unique([serviceId, sectorId, functionName, position])
}

model ScheduleSlotChange {
  id                String                 @id @default(cuid())
  slotId            String
  changeType        ScheduleSlotChangeType
  fromServantId     String?
  toServantId       String?
  reason            String?
  metadata          Json?
  performedByUserId String
  createdAt         DateTime               @default(now())
  slot              ScheduleSlot           @relation(fields: [slotId], references: [id], onDelete: Cascade)
  performedBy       User                   @relation("PerformedScheduleSlotChanges", fields: [performedByUserId], references: [id], onDelete: Cascade)

  @@index([slotId, createdAt])
  @@index([changeType, createdAt])
  @@index([performedByUserId])
}

model ScheduleResponseHistory {
  id                String                 @id @default(cuid())
  scheduleId        String
  responseStatus    ScheduleResponseStatus
  declineReason     String?
  respondedByUserId String
  respondedAt       DateTime               @default(now())
  schedule          Schedule               @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  respondedBy       User                   @relation("RespondedScheduleAssignments", fields: [respondedByUserId], references: [id], onDelete: Cascade)

  @@index([scheduleId, respondedAt])
  @@index([respondedByUserId])
}

model ServantAvailability {
  id        String   @id @default(cuid())
  servantId String
  dayOfWeek Int
  shift     Shift
  available Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  servant   Servant  @relation(fields: [servantId], references: [id], onDelete: Cascade)

  @@unique([servantId, dayOfWeek, shift])
  @@index([servantId])
}

model ScheduleSwapHistory {
  id                String   @id @default(cuid())
  fromScheduleId    String
  toScheduleId      String
  reason            String?
  swappedByUserId   String
  createdAt         DateTime @default(now())
  fromSchedule      Schedule @relation("SwapFromSchedule", fields: [fromScheduleId], references: [id], onDelete: Cascade)
  toSchedule        Schedule @relation("SwapToSchedule", fields: [toScheduleId], references: [id], onDelete: Cascade)
  swappedBy         User     @relation("SwappedByUser", fields: [swappedByUserId], references: [id])

  @@index([createdAt])
  @@index([swappedByUserId])
}

model Attendance {
  id                 String           @id @default(cuid())
  serviceId          String
  servantId          String
  status             AttendanceStatus
  justification      String?
  notes              String?
  registeredByUserId String
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  service            WorshipService   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  servant            Servant          @relation(fields: [servantId], references: [id], onDelete: Cascade)
  registeredBy       User             @relation("RegisteredAttendances", fields: [registeredByUserId], references: [id])

  @@index([serviceId])
  @@index([servantId])
  @@index([status])
  @@unique([serviceId, servantId])
}

model PastoralVisit {
  id               String             @id @default(cuid())
  servantId        String
  reason           String
  status           PastoralVisitStatus @default(ABERTA)
  openedAt         DateTime           @default(now())
  resolvedAt       DateTime?
  notes            String?
  createdByUserId  String
  resolvedByUserId String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  servant          Servant            @relation(fields: [servantId], references: [id], onDelete: Cascade)
  createdBy        User               @relation("CreatedPastoralVisits", fields: [createdByUserId], references: [id])
  resolvedBy       User?              @relation("ResolvedPastoralVisits", fields: [resolvedByUserId], references: [id])

  @@index([servantId])
  @@index([status])
  @@index([openedAt])
}

model PastoralWeeklyFollowUp {
  id                String   @id @default(cuid())
  servantId         String
  sectorId          String
  scheduleId        String?
  weekStartDate     DateTime
  contactedAt       DateTime @default(now())
  notes             String?
  responsibleUserId String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  servant           Servant  @relation(fields: [servantId], references: [id], onDelete: Cascade)
  sector            Sector   @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  schedule          Schedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  responsible       User     @relation("PastoralWeeklyFollowUpResponsible", fields: [responsibleUserId], references: [id], onDelete: Cascade)

  @@unique([servantId, sectorId, weekStartDate])
  @@index([weekStartDate])
  @@index([servantId, weekStartDate])
  @@index([sectorId, weekStartDate])
  @@index([scheduleId])
  @@index([responsibleUserId])
}

model DailyDevotional {
  id                 String           @id @default(cuid())
  servantId          String
  devotionalDate     DateTime
  status             DevotionalStatus @default(DONE)
  notes              String?
  registeredByUserId String
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  servant            Servant          @relation(fields: [servantId], references: [id], onDelete: Cascade)
  registeredBy       User             @relation("DailyDevotionalRegisteredBy", fields: [registeredByUserId], references: [id], onDelete: Cascade)

  @@unique([servantId, devotionalDate])
  @@index([devotionalDate])
  @@index([servantId, devotionalDate])
  @@index([registeredByUserId])
}

model MonthlyFasting {
  id                 String               @id @default(cuid())
  servantId          String
  referenceMonth     DateTime
  status             MonthlyFastingStatus @default(PENDING)
  completedAt        DateTime?
  notes              String?
  registeredByUserId String
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  servant            Servant              @relation(fields: [servantId], references: [id], onDelete: Cascade)
  registeredBy       User                 @relation("MonthlyFastingRegisteredBy", fields: [registeredByUserId], references: [id], onDelete: Cascade)

  @@unique([servantId, referenceMonth])
  @@index([referenceMonth])
  @@index([servantId, referenceMonth])
  @@index([registeredByUserId])
}

model PastoralAlert {
  id               String      @id @default(cuid())
  servantId        String
  message          String
  status           AlertStatus @default(OPEN)
  trigger          String
  createdAt        DateTime    @default(now())
  resolvedAt       DateTime?
  createdByUserId  String?
  resolvedByUserId String?
  servant          Servant     @relation(fields: [servantId], references: [id], onDelete: Cascade)
  createdBy        User?       @relation("AlertCreatedBy", fields: [createdByUserId], references: [id])
  resolvedBy       User?       @relation("AlertResolvedBy", fields: [resolvedByUserId], references: [id])

  @@index([servantId])
  @@index([status])
}

model Talent {
  id         String      @id @default(cuid())
  servantId  String
  stage      TalentStage
  reviewStatus TalentReviewStatus @default(NOT_REQUIRED)
  rejectionReason String?
  rejectedByUserId String?
  rejectedAt  DateTime?
  reviewedByUserId String?
  reviewedAt  DateTime?
  reviewNotes String?
  notes      String?
  approvedAt DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  servant    Servant     @relation(fields: [servantId], references: [id], onDelete: Cascade)
  rejectedBy User?       @relation("TalentRejectedBy", fields: [rejectedByUserId], references: [id], onDelete: SetNull)
  reviewedBy User?       @relation("TalentReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([servantId])
  @@index([stage])
  @@index([reviewStatus])
  @@index([rejectedByUserId])
  @@index([reviewedByUserId])
}

model SupportRequest {
  id             String               @id @default(cuid())
  type           SupportRequestType
  subject        String
  description    String
  reference      String?
  status         SupportRequestStatus @default(ABERTO)
  authorUserId   String
  handledByUserId String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  handledAt      DateTime?
  author         User                 @relation("SupportRequestAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)
  handledBy      User?                @relation("SupportRequestHandler", fields: [handledByUserId], references: [id], onDelete: SetNull)

  @@index([authorUserId, createdAt])
  @@index([status, createdAt])
  @@index([type, createdAt])
}

model MinistryResponsibility {
  id                  String   @id @default(cuid())
  ministryId          String
  title               String
  activity            String?
  functionName        String?
  description         String?
  responsibleServantId String?
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  ministry            Sector   @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  responsibleServant  Servant? @relation("ResponsibilityOwnerServant", fields: [responsibleServantId], references: [id], onDelete: SetNull)
  scheduleSlots       ScheduleSlot[]

  @@index([ministryId, active])
  @@index([responsibleServantId])
}

model ServantReward {
  id              String       @id @default(cuid())
  servantId       String
  source          RewardSource
  points          Int
  title           String
  description     String?
  referenceId     String?
  grantedByUserId String?
  rewardedAt      DateTime     @default(now())
  createdAt       DateTime     @default(now())
  servant         Servant      @relation(fields: [servantId], references: [id], onDelete: Cascade)
  grantedBy       User?        @relation("ServantRewardGrantedBy", fields: [grantedByUserId], references: [id], onDelete: SetNull)

  @@index([servantId, rewardedAt])
  @@index([source, rewardedAt])
  @@index([grantedByUserId])
  @@unique([servantId, source, referenceId])
}

model AuditLog {
  id         String      @id @default(cuid())
  action     AuditAction
  entity     String
  entityId   String
  metadata   Json?
  userId     String?
  createdAt  DateTime    @default(now())
  user       User?       @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([action])
  @@index([createdAt])
}

model UserScopeBinding {
  id        String   @id @default(cuid())
  userId    String
  sectorId  String?
  teamId    String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sector    Sector?  @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  team      Team?    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sectorId])
  @@index([teamId])
  @@unique([userId, sectorId, teamId])
}

model UserPermissionOverride {
  id            String           @id @default(cuid())
  userId        String
  permissionKey String
  effect        PermissionEffect
  reason        String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionKey])
  @@index([userId])
  @@index([permissionKey])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  link      String?
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@index([type])
}

model NotificationTemplate {
  id          String                     @id @default(cuid())
  eventKey    String
  channel     NotificationChannel
  provider    NotificationProvider?      @default(MOCK)
  name        String
  content     String
  variables   Json?
  status      NotificationTemplateStatus @default(ACTIVE)
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  queueItems  NotificationQueue[]
  logs        NotificationLog[]

  @@unique([eventKey, channel])
  @@index([channel, status])
}

model NotificationPreference {
  id        String              @id @default(cuid())
  userId    String?
  servantId String?
  channel   NotificationChannel
  enabled   Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  user      User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  servant   Servant?            @relation(fields: [servantId], references: [id], onDelete: Cascade)

  @@index([channel, enabled])
  @@unique([userId, channel])
  @@unique([servantId, channel])
}

model NotificationQueue {
  id                String                @id @default(cuid())
  eventKey          String
  channel           NotificationChannel   @default(WHATSAPP)
  provider          NotificationProvider  @default(MOCK)
  status            NotificationQueueStatus @default(PENDING)
  userId            String?
  servantId         String?
  recipientPhone    String
  recipientName     String?
  templateId        String?
  payload           Json?
  renderedMessage   String
  attemptCount      Int                   @default(0)
  maxAttempts       Int                   @default(3)
  nextRetryAt       DateTime              @default(now())
  lockedAt          DateTime?
  processedAt       DateTime?
  providerMessageId String?
  lastError         String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  user              User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  servant           Servant?              @relation(fields: [servantId], references: [id], onDelete: SetNull)
  template          NotificationTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  logs              NotificationLog[]

  @@index([channel, status, nextRetryAt])
  @@index([userId, createdAt])
  @@index([servantId, createdAt])
}

model NotificationLog {
  id                String                   @id @default(cuid())
  queueId           String?
  eventKey          String
  channel           NotificationChannel      @default(WHATSAPP)
  provider          NotificationProvider     @default(MOCK)
  status            NotificationDeliveryStatus
  userId            String?
  servantId         String?
  recipientPhone    String
  templateId        String?
  payload           Json?
  providerMessageId String?
  error             String?
  attempt           Int                      @default(1)
  sentAt            DateTime?
  createdAt         DateTime                 @default(now())
  queue             NotificationQueue?       @relation(fields: [queueId], references: [id], onDelete: SetNull)
  template          NotificationTemplate?    @relation(fields: [templateId], references: [id], onDelete: SetNull)
  user              User?                    @relation(fields: [userId], references: [id], onDelete: SetNull)
  servant           Servant?                 @relation(fields: [servantId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([status, channel])
  @@index([eventKey, createdAt])
}

model NotificationSystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}
